{
  "name": "feishu-md-sync-monorepo",
  "version": "0.1.0",
  "description": "Workspace root for the feishu-md-sync CLI and documentation site.",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/cli",
    "apps/docs"
  ],
  "scripts": {
    "build": "npm run build --workspace=feishu-md-sync && node scripts/deprecate-root-dist-cli.mjs",
    "test": "npm run test --workspace=feishu-md-sync",
    "test:coverage": "npm run test:coverage --workspace=feishu-md-sync",
    "typecheck": "npm run typecheck --workspace=feishu-md-sync",
    "dev": "npm run dev --workspace=feishu-md-sync --",
    "docs:dev": "npm run dev --workspace=@feishu-md-sync/docs --",
    "docs:build": "npm run build --workspace=@feishu-md-sync/docs",
    "docs:preview": "npm run preview --workspace=@feishu-md-sync/docs --"
  },
  "devDependencies": {
    "feishu-md-sync": "*"
  }
}
