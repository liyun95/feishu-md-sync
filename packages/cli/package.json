{
  "name": "feishu-md-sync",
  "version": "0.6.1",
  "description": "Dry-run-first sync between local Markdown and Feishu/Lark documents using the official lark-cli.",
  "keywords": [
    "feishu",
    "lark",
    "markdown",
    "sync",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liyun95/feishu-md-sync.git",
    "directory": "packages/cli"
  },
  "homepage": "https://liyun95.github.io/feishu-md-sync/",
  "bugs": {
    "url": "https://github.com/liyun95/feishu-md-sync/issues"
  },
  "type": "module",
  "bin": {
    "feishu-md-sync": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "npm run clean && tsc -p tsconfig.json && node scripts/ensure-bin-executable.mjs",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:live:feishu": "vitest run test/live-feishu-publish.test.ts && vitest run test/live-feishu-merge.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:package": "npm run build && node scripts/package-smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "feishu-docx-engine": "0.1.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "parse5": "^7.3.0",
    "saxes": "^6.0.0",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
