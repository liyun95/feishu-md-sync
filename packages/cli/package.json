{
  "name": "feishu-md-sync",
  "version": "0.1.0",
  "description": "Sync one local Markdown file to an existing Feishu document with dry-run-first conflict checks.",
  "type": "module",
  "bin": {
    "feishu-md-sync": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:live:feishu": "vitest run test/live-feishu-publish.test.ts && vitest run test/live-feishu-merge.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:package": "node scripts/package-smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
