# Copy this file to .env and fill in your Feishu app credentials.
APP_ID=
APP_SECRET=

# Optional. The CLI defaults to https://open.feishu.cn when omitted.
FEISHU_HOST=https://open.feishu.cn

# Optional. Used to print browser URLs when Feishu create APIs return only doc ids.
# Example: https://zilliverse.feishu.cn
FEISHU_WEB_BASE_URL=

# Optional publish-new defaults.
# To create documents owned directly by the Feishu app, set:
FEISHU_PUBLISH_APP_OWNED=false

# Drive-folder publish only needs FEISHU_PUBLISH_FOLDER_TOKEN.
# Wiki publish needs all three values below: a staging Drive folder, wiki space id,
# and target parent wiki node token.
FEISHU_PUBLISH_FOLDER_TOKEN=
FEISHU_PUBLISH_SPACE_ID=
FEISHU_PUBLISH_PARENT_NODE_TOKEN=
